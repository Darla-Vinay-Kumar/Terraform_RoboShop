# Local .terraform directories
**/.terraform/*

# Terraform state files (contain sensitive data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan output files
*.tfplan

# Ignore variable files (may contain secrets)
*.tfvars
*.tfvars.json

# Ignore sensitive environment files
.env

# Ignore logs
*.log

# Mac system files
.DS_Store

# Windows system files
Thumbs.db